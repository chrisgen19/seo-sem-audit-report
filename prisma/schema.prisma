generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  claudeApiKey String?   // AES-256-GCM encrypted
  geminiApiKey String?   // AES-256-GCM encrypted
  claudeModel  String?
  geminiModel  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  accounts     Account[]
  sessions     Session[]
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  domain    String   // e.g. https://accessindigenous.com.au
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages     Page[]
}

model Page {
  id        String     @id @default(cuid())
  projectId String
  name      String     // e.g. "Home", "About Us"
  url       String     // e.g. https://accessindigenous.com.au/about-us/
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditRuns AuditRun[]
}

model AuditRun {
  id             String       @id @default(cuid())
  pageId         String
  url            String
  status         String       @default("pending") // pending | running | done | failed
  provider       String       // claude | gemini
  overallScore   Int?
  overallGrade   String?
  technicalScore Int?
  technicalGrade String?
  contentScore   Int?
  contentGrade   String?
  semScore       Int?
  semGrade       String?
  errorMessage   String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?
  page           Page         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  checks         AuditCheck[]
  meta           AuditMeta?
}

model AuditCheck {
  id             String   @id @default(cuid())
  auditRunId     String
  section        String   // technical | content | sem
  name           String
  status         String   // PASS | WARN | FAIL
  finding        String
  recommendation String
  auditRun       AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
}

model AuditMeta {
  id               String   @id @default(cuid())
  auditRunId       String   @unique
  businessName     String?
  businessDesc     String?
  executiveSummary String
  keyStrengths     String
  keyOpportunities String
  quickWins        Json
  adGroups         Json
  priorityActions  Json
  semStrengths     Json
  semIssues        Json
  campaignRecs     Json
  rawCrawlData     Json
  auditRun         AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
